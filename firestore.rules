rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // 🔹 HELPER FUNCTIONS
    // =========================

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return isAuthenticated() && exists(userDocPath());
    }

    function getUserData() {
      return userExists() ? get(userDocPath()).data : null;
    }

    function isAdmin() {
      return userExists() && getUserData().role == "admin";
    }

    function isOwner() {
      return userExists() && getUserData().role == "owner";
    }

    // 👉 owner cũng có thể thuê xe (rất thực tế)
    function isRenter() {
      return userExists() &&
        (getUserData().role == "renter" || getUserData().role == "owner");
    }

    function isVerifiedOwner() {
      return isOwner() &&
        getUserData() != null &&
        getUserData().isVerified == true;
    }

    // =========================
    // 👤 USERS & PROFILES
    // =========================
    match /users/{userId} {
      allow read: if isAuthenticated();
      // user chỉ sửa chính mình
      allow update: if isAuthenticated() && request.auth.uid == userId;
      // chỉ cho tạo doc đúng uid của mình
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // admin xóa
      allow delete: if isAdmin();
    }

    // 🎯 ĐÂY LÀ CHỖ BỊ THIẾU KHIẾN BẠN LỖI KHÔNG LẤY ĐƯỢC TÊN:
    match /publicProfiles/{userId} {
      allow read: if true; // Profile công khai thì ai cũng được phép gọi để xem tên/avatar
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // =========================
    // 🚚 TRUCKS
    // =========================
    match /trucks/{truckId} {
      // ai cũng xem được
      allow read: if true;
      // chỉ owner đã verify mới đăng xe
      allow create: if isOwner(); 
      // update: check cả data cũ + mới
      allow update: if isOwner() &&
        resource.data.ownerId == request.auth.uid &&
        request.resource.data.ownerId == request.auth.uid;
      // delete: check owner
      allow delete: if isOwner() && resource.data.ownerId == request.auth.uid;
      // admin full quyền
      allow write: if isAdmin();
    }

    // =========================
    // 📦 BOOKINGS
    // =========================
    match /bookings/{bookingId} {
      // ✅ renter tạo booking (phải là chính nó)
      allow create: if isAuthenticated() &&
        request.resource.data.renterId == request.auth.uid;
      // ✅ chỉ renter hoặc owner được xem
      allow read: if isAuthenticated() &&
        (
          resource.data.renterId == request.auth.uid ||
          resource.data.ownerId == request.auth.uid
        );
      // ✅ update: chỉ 2 bên liên quan
      allow update: if isAuthenticated() &&
        (
          resource.data.renterId == request.auth.uid ||
          resource.data.ownerId == request.auth.uid
        );
      allow delete: if isAdmin();
    }

    // =========================
    // 💬 MESSAGES (CHAT)
    // =========================
    match /messages/{messageId} {
      allow create: if isAuthenticated();
      // 🎯 Đã sửa lại vì Message ko có field receiverId, chỉ có senderId và bookingId
      allow read: if isAuthenticated() && 
        (
          resource.data.senderId == request.auth.uid || 
          get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.ownerId == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.renterId == request.auth.uid
        );
      allow delete: if isAdmin();
    }

    match /ownerMessages/{messageId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && 
        (resource.data.senderId == request.auth.uid || resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // =========================
    // ⭐ REVIEWS
    // =========================
    match /reviews/{reviewId} {
      allow create: if isRenter();
      allow read: if true;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // =========================
    // 🚨 REPORTS
    // =========================
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // =========================
    // 📄 VERIFICATION REQUESTS
    // =========================
    match /verification_requests/{id} {
      allow create: if isOwner();
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
